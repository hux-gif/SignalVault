# Public Coston2 endpoint; override only when necessary.
COSTON2_RPC_URL=https://coston2-api.flare.network/ext/C/rpc

# Set this only in your local environment. Never commit a real private key.
COSTON2_PRIVATE_KEY=

# The script searches base-unit powers of ten up to this safety ceiling.
UPSHIFT_SMOKE_MAX_AMOUNT=0.01
